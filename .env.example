# Railway Environment Variables Example
# Copy this file to .env for local development

# Port configuration
PORT=6080
NOVNC_PORT=6080

# Display configuration
DISPLAY=:1
RESOLUTION=1920x1080
COLOR_DEPTH=24

# Security
VNC_PASSWORD=robloxstudio2024

# Environment
NODE_ENV=production

# Railway specific (automatically set by Railway)
# RAILWAY_STATIC_URL=
# RAILWAY_PUBLIC_DOMAIN=